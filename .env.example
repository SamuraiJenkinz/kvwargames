# ─── Frontend Environment Variables ──────────────────────────────────────────
# Variables prefixed with VITE_ are bundled into the client build.
# Safe to expose — do NOT put secrets here.

VITE_APP_TITLE=EDIP Wargame

# ─── Backend (Server-Only) Environment Variables ─────────────────────────────
# These are read by the Python backend only and are NEVER exposed to the browser.
# Copy this file to .env and fill in real values. Never commit .env.

# ─── MMC corporate gateway (Azure OpenAI via coreapi proxy) ──────────────────
# Full endpoint URL including deployment path AND ?api-version= query string.
# The api-version is not a separate env var — inject it into the URL (decision 06-01).
LLM_ENDPOINT_URL=https://stg1.mmc-dallas-int-non-prod-ingress.mgti.mmc.com/coreapi/openai/v1/deployments/mmc-tech-gpt-4o-mini-128k-2024-07-18/chat/completions?api-version=2024-08-01-preview

# PASTE REAL KEY ON SERVER — never commit the real value to a public repo.
LLM_API_KEY=REPLACE_ME_WITH_REAL_KEY

# Model identifier sent in the request body. For Azure, this is typically the
# deployment name. Our MMC gateway routes by URL path, so match the URL here:
LLM_MODEL=mmc-tech-gpt-4o-mini-128k-2024-07-18

# ─── Azure-style auth header (required for MMC gateway) ──────────────────────
# Default (unset) is OpenAI-style `Authorization: Bearer <key>`.
# Azure / MMC gateway uses `api-key: <key>` with no prefix.
LLM_AUTH_HEADER_NAME=api-key
LLM_AUTH_VALUE_PREFIX=

# Upstream request timeout in seconds (default: 60)
LLM_TIMEOUT_SECONDS=60

# Maximum tokens for LLM response generation (default: 2048)
LLM_MAX_TOKENS=2048

# Extra HTTP headers as a JSON object (e.g. for corporate proxies)
# Example: {"X-Custom-Header": "value"}
LLM_EXTRA_HEADERS={}

# ─── Server Bind (production deployment) ─────────────────────────────────────
# Set APP_HOST=0.0.0.0 for LAN-accessible deployment (Windows Server at boot).
# Use 127.0.0.1 for local-only.
APP_HOST=0.0.0.0
APP_PORT=8000
