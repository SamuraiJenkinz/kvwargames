# ─── Frontend Environment Variables ──────────────────────────────────────────
# Variables prefixed with VITE_ are bundled into the client build.
# Safe to expose — do NOT put secrets here.

VITE_APP_TITLE=EDIP Wargame

# ─── Backend (Server-Only) Environment Variables ─────────────────────────────
# These are read by the Python backend only and are NEVER exposed to the browser.
# Copy this file to .env and fill in real values. Never commit .env.

# Your corporate LLM API endpoint (OpenAI-compatible)
LLM_ENDPOINT=https://your-corporate-llm-endpoint.com/v1/chat/completions

# API key for the LLM service
LLM_API_KEY=your-api-key-here

# Model name to request from the endpoint
LLM_MODEL=gpt-4

# Maximum tokens for LLM response generation
LLM_MAX_TOKENS=4096

# Extra HTTP headers as a JSON object (e.g. for corporate proxies or auth headers)
# Example: {"X-Custom-Header": "value", "Authorization": "Bearer token"}
LLM_EXTRA_HEADERS={}
