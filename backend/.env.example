# =============================================================================
# KV War Game — backend environment variables
# Copy to backend/.env and fill in your deployment's values.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — server will refuse to start if any of these are missing.
# -----------------------------------------------------------------------------

# API key for the upstream LLM endpoint. Injected into the auth header on every
# outbound call and NEVER echoed in responses or logs.
LLM_API_KEY=your-api-key-here

# Full URL of the chat-completions endpoint.
# Standard OpenAI example:
#   https://api.openai.com/v1/chat/completions
# Azure OpenAI example (note deployment path and api-version query string):
#   https://your-resource.openai.azure.com/openai/deployments/your-deployment/chat/completions?api-version=2024-02-15-preview
LLM_ENDPOINT_URL=https://api.openai.com/v1/chat/completions

# Model identifier string forwarded as the `model` field in the payload.
# For Azure OpenAI, this is typically the deployment name.
LLM_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# OPTIONAL — sensible defaults are applied if these are unset.
# -----------------------------------------------------------------------------

# HTTP timeout in seconds applied to the shared httpx client.
# LLM_TIMEOUT_SECONDS=60

# Maximum tokens per completion request.
# LLM_MAX_TOKENS=2048

# JSON object string merged into outbound headers (after auth / content-type).
# Useful for corporate proxies that require extra tracing or routing headers.
# LLM_EXTRA_HEADERS={"X-Trace-Id":"edip"}

# -----------------------------------------------------------------------------
# Auth header configuration (Plan 06-01)
# -----------------------------------------------------------------------------
# The backend proxy supports both OpenAI-compatible and Azure OpenAI auth.
# Default behaviour (unset) = OpenAI compatible: Authorization: Bearer <key>
#
# LLM_AUTH_HEADER_NAME defaults to "Authorization".
# LLM_AUTH_VALUE_PREFIX defaults to "Bearer " (trailing space intentional —
# f"{prefix}{key}".strip() yields "Bearer <key>").
#
# LLM_AUTH_HEADER_NAME=Authorization
# LLM_AUTH_VALUE_PREFIX=Bearer

# Azure OpenAI (uses `api-key` header, no Bearer prefix):
# LLM_AUTH_HEADER_NAME=api-key
# LLM_AUTH_VALUE_PREFIX=
